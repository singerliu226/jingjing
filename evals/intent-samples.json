      "text": "运营说朋友圈那张主标题不够突出，今天下班前要给她。",
      "expected": {
        "intent": "record_feedback",
        "entities": {
          "source": "运营",
          "dueDate": "2026-06-12",
          "deliverables": ["朋友圈海报"],
          "feedback": {
            "rawIncludes": ["主标题不够突出"],
            "actionIncludes": ["主标题", "突出"]
