{
  "schemaVersion": "llm-intent-evals-v1",
  "currentDate": "2026-06-12",
  "description": "菁菁小画桌结构化意图评估样例。用于验证模型是否能把初级平面设计师的自然表达转成稳定的 LLMIntent。",
  "samples": [
    {
      "id": "feedback-001",
      "text": "主管说海报颜色太暗，要更年轻一点，明天下午前改。",
      "expected": {
        "intent": "record_feedback",
        "entities": {
          "source": "主管",
          "dueDate": "2026-06-13",
          "feedback": {
            "rawIncludes": ["颜色太暗", "更年轻"],
            "actionIncludes": ["明度", "年轻"]
          }
        },
        "missingContains": []
      }
    },
    {
      "id": "feedback-002",
      "text": "客户反馈这版不像品牌，但没说具体哪里不像。",
      "expected": {
        "intent": "record_feedback",
        "entities": {
          "source": "客户",
          "feedback": {
            "rawIncludes": ["不像品牌"],
            "actionIncludes": ["品牌"]
          }
        },
        "missingContains": ["截止时间"]
      }
    },
    {
      "id": "feedback-003",
      "text": "老板说字太小，二维码和活动时间都要清楚。",
      "expected": {
        "intent": "record_feedback",
        "entities": {
          "source": "老板",
          "feedback": {
            "rawIncludes": ["字太小", "二维码"],
            "actionIncludes": ["可读", "二维码"]
          }
        },
        "missingContains": ["截止时间"]
      }
