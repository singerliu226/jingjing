# Existing web application
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_VISION_MODEL=qwen-vl-plus

# Local Context Bridge (use a different secret from DASHSCOPE_API_KEY)
DESIGN_DESK_API_TOKEN=replace-with-a-long-random-local-token
CONTEXT_BRIDGE_STORE_FILE=/opt/jingjing/data/context-bridge-events.json

# WeChat Mini Program
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=
WECHAT_SESSION_SECRET=replace-with-a-long-random-secret

# WeChat Service Account
WECHAT_OA_APP_ID=
WECHAT_OA_APP_SECRET=
WECHAT_OA_TEMPLATE_ID=
WECHAT_OA_TEMPLATE_FIELDS={"title":"thing1","time":"time2","action":"thing3"}
WECHAT_PUBLIC_BASE_URL=https://your-domain.example

# Notification scheduler
WECHAT_NOTIFICATION_ADMIN_TOKEN=replace-with-a-long-random-token
WECHAT_STORE_FILE=/opt/jingjing/data/wechat-store.json
