page {
  height: 100%;
  background: #f4f6f5;
  color: #17201d;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

button {
  border-radius: 4px;
  letter-spacing: 0;
}

button::after {
  border: 0;
}

.safe-page {
  min-height: 100%;
  padding-bottom: env(safe-area-inset-bottom);
}

.empty {
  padding: 80rpx 32rpx;
  color: #68736f;
  font-size: 26rpx;
  line-height: 1.7;
  text-align: center;
}
